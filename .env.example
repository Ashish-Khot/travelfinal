# Environment Configuration Example
# Copy this to .env in the Travel root directory and fill in your values

# ========== OPENTRIPMAP API ==========
# Get your free API key from: https://opentripmap.org/dev/signup
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here

# ========== OPENWEATHER ==========
# Free weather forecast API
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ========== OPENROUTER (FREE AI MODELS) ==========
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/free

# ========== OPENAI (OPTIONAL FALLBACK) ==========
# Optional provider, disabled in itinerary default chain unless added to AI_PROVIDER_SEQUENCE
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-oss-120b
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=130000

# ========== ITINERARY AI ROUTING ==========
# Gemini first for itinerary, then OpenRouter fallback
# Dedicated itinerary-only keys and model controls
ITINERARY_AI_PROVIDER=gemini
ITINERARY_AI_PROVIDER_SEQUENCE=gemini,openrouter
ITINERARY_GEMINI_API_KEY=
ITINERARY_GEMINI_MODEL=gemini-2.5-flash
ITINERARY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
ITINERARY_GEMINI_VISION_MODEL=
ITINERARY_OPENROUTER_API_KEY=
ITINERARY_OPENROUTER_MODEL=openrouter/free
ITINERARY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Legacy shared AI routing (optional, used by non-itinerary modules)
AI_PROVIDER=gemini
AI_PROVIDER_SEQUENCE=gemini,openrouter

# ========== GROQ (LOW LATENCY AI) ==========
# Sign up: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ========== VIRTUAL GUIDE AI ==========
# Optional: force one provider first (openai | openrouter | groq). Leave empty for sequence order.
GUIDE_AI_PROVIDER=
# Ordered failover chain for virtual guide
GUIDE_AI_PROVIDER_SEQUENCE=openai,openrouter,groq
# Guide-specific model overrides (keeps itinerary OPENAI_MODEL separate)
GUIDE_AI_OPENAI_MODEL=gpt-oss-20b
GUIDE_AI_OPENROUTER_MODEL=openai/gpt-oss-20b
GUIDE_AI_GROQ_MODEL=llama-3.3-70b-versatile
GUIDE_AI_STREAM_TIMEOUT_MS=45000



# ========== SERVER CONFIG ==========
PORT=3001
NODE_ENV=development

# ========== DATABASE ==========
MONGODB_URI=mongodb://localhost:27017/travel

# ========== FRONTEND ==========
VITE_API_BASE_URL=http://localhost:3001

# ========== CLIENT (if needed) ==========
# Add VITE variables here that you want to use in frontend
VITE_APP_TITLE=Travel Booking Platform

# ========== GEMINI AI ==========
# Get your key from Google AI Studio
GEMINI_API_KEY=
# Optional: override model or base URL if needed
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MAX_IMAGE_MB=4

# ========== AMADEUS (HOTELS) ==========
# Sign up: https://developers.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here

# ========== FREE SOURCES (NO KEY REQUIRED) ==========
# Wikipedia API and Nominatim geocoding are used automatically.

# ========== FRONTEND (VITE) ==========
# NOTE: Put VITE_* variables in client/.env (frontend). Root .env is not read by Vite.

# Map provider for destination map (osm | ola)
VITE_MAP_PROVIDER=osm
# Ola Maps API key (optional - required only when VITE_MAP_PROVIDER=ola)
VITE_OLA_MAPS_API_KEY=
# Ola raster tile URL template (optional)
# Example format expected by map component:
# https://your-ola-tile-endpoint/{z}/{x}/{y}.png?api_key={apiKey}
VITE_OLA_MAPS_TILE_URL=
