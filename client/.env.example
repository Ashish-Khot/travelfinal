# Environment Variables - Vite Frontend
# Copy this file to client/.env and fill in your API keys
# Use the VITE_ prefix for variables that the frontend reads

# ============================================================================
# OPENTRIPMAP - Emergency Support (Hospitals/Geocoding)
# ============================================================================
# Get FREE API key from: https://opentripmap.org/dev/signup
VITE_OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here

# ============================================================================
# OPENWEATHERMAP - Weather widgets/search
# ============================================================================
# Get API key from: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ============================================================================
# OPENROUTESERVICE - Routing & Directions
# ============================================================================
# Get FREE API key from: https://openrouteservice.org/
# Free tier: 50 requests/day, up to 10 endpoints per request
# Upgrade available for production use

VITE_OPENROUTESERVICE_KEY=your_openrouteservice_key_here

# ============================================================================
# UNSPLASH - Place Search Images
# ============================================================================
# Get API key from: https://unsplash.com/developers
# Demo mode limit is low (typically 50 requests/hour), so app-side caching is used.
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ============================================================================
# NOMINATIM (OpenStreetMap) - Search & Geocoding
# ============================================================================
# Nominatim is provided by OpenStreetMap Foundation
# No API key required! ✓
# Rate limit: ~3600 requests/hour

# Optional: Nominatim API URL (default is OSM's public server)
# REACT_APP_NOMINATIM_URL=https://nominatim.openstreetmap.org

# ============================================================================
# MAP TILES CONFIGURATION
# ============================================================================
# Multiple free tile providers available:

# OpenStreetMap (default)
# No key required ✓

# CartoDB (free tier)
# No key required ✓

# For production, consider:
# - Mapbox: REACT_APP_MAPBOX_KEY=your_key
# - Stadia Maps: REACT_APP_STADIA_KEY=your_key
# - Thunderforest: REACT_APP_THUNDERFOREST_KEY=your_key

# ============================================================================
# OPTIONAL: Analytics & Monitoring
# ============================================================================

# Enable map performance monitoring
REACT_APP_MAP_ANALYTICS=true

# Enable cache statistics
REACT_APP_SHOW_CACHE_STATS=true

# ============================================================================
# NOTES
# ============================================================================
# 1. Copy this file to .env.local (add to .gitignore!)
# 2. Fill in your OpenRouteService API key
# 3. Other APIs don't require keys (free & open source)
# 4. For production, consider upgrading OpenRouteService plan
# 5. All requests go directly from browser (client-side rendering)
#
# SECURITY: Never commit .env.local to Git!
# .gitignore should include: .env.local, .env*.local

# Virtual Guide now auto-selects provider/model on backend failover.
